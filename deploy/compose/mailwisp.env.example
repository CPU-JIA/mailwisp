MAILWISP_LOG_LEVEL=info
MAILWISP_SHUTDOWN_TIMEOUT=20s
MAILWISP_TRUSTED_PROXY_CIDRS=172.16.0.0/12

MAILWISP_PUBLIC_DOMAINS=example.com
MAILWISP_INBOX_DEFAULT_TTL=24h
MAILWISP_INBOX_MAX_TTL=168h
MAILWISP_INBOX_MAX_MESSAGES=500
MAILWISP_INBOX_MAX_STORAGE_BYTES=268435456
MAILWISP_CLEANUP_BATCH_SIZE=100
MAILWISP_CLEANUP_INTERVAL=5m
MAILWISP_CLEANUP_TIMEOUT=2m
MAILWISP_DUCKMAIL_ENABLED=false
MAILWISP_YYDS_ENABLED=false
MAILWISP_CLOUDFLARE_TEMP_ENABLED=false
MAILWISP_CLOUDFLARE_LEGACY_PATHS_ENABLED=false

MAILWISP_LMTP_HOSTNAME=mx.example.com
MAILWISP_LMTP_MAX_MESSAGE_BYTES=26214400
MAILWISP_LMTP_MAX_SESSIONS=64

MAILWISP_PARSER_WORKERS=2
