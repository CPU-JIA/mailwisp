compatibility_level = 3.11

queue_directory = /var/spool/postfix
command_directory = /usr/sbin
daemon_directory = /usr/libexec/postfix
data_directory = /var/lib/postfix
mail_owner = postfix
setgid_group = postdrop

myhostname = postfix.integration.test
mydomain = integration.test
myorigin = $myhostname
mydestination =
alias_maps =
alias_database =
relay_domains = example.test
relay_transport = error:4.3.0 LMTP target not configured
default_transport = error:5.1.2 External delivery disabled

inet_interfaces = all
inet_protocols = ipv4
mynetworks = 127.0.0.0/8

smtpd_banner = $myhostname ESMTP
smtpd_helo_required = yes
smtpd_relay_restrictions = reject_unauth_destination
smtpd_recipient_restrictions = reject_unauth_pipelining
strict_rfc821_envelopes = yes
disable_vrfy_command = yes
allow_percent_hack = no
swap_bangpath = no

message_size_limit = 26214400
mailbox_size_limit = 0
recipient_delimiter = +

lmtp_host_lookup = native
lmtp_tls_security_level = none
lmtp_connect_timeout = 2s
lmtp_lhlo_timeout = 5s
lmtp_mail_timeout = 5s
lmtp_rcpt_timeout = 5s
lmtp_data_init_timeout = 5s
lmtp_data_xfer_timeout = 10s
lmtp_data_done_timeout = 5s
lmtp_quit_timeout = 5s
lmtp_connection_cache_on_demand = no
lmtp_destination_concurrency_limit = 1
lmtp_destination_recipient_limit = 1

minimal_backoff_time = 60s
maximal_backoff_time = 60s
queue_run_delay = 60s
maximal_queue_lifetime = 1d
bounce_queue_lifetime = 1d
delay_warning_time = 0h

default_process_limit = 20
initial_destination_concurrency = 1
default_destination_concurrency_limit = 1

maillog_file = /dev/stdout
notify_classes =
