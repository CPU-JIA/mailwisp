limit_req_zone $binary_remote_addr zone=mailwisp_create:10m rate=12r/m;

server {
    listen 80;
    listen [::]:80;
    server_name MAILWISP_WEB_DOMAIN;

    location ^~ /.well-known/acme-challenge/ {
        root /var/lib/letsencrypt;
        default_type text/plain;
    }

    location / {
        return 308 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name MAILWISP_WEB_DOMAIN;

    ssl_certificate /etc/letsencrypt/live/MAILWISP_CERT_NAME/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/MAILWISP_CERT_NAME/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:MailWispTLS:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    root /var/www/mailwisp;
    index index.html;
    client_max_body_size 64k;

    add_header Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-src 'self'; upgrade-insecure-requests" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()" always;
    add_header Cross-Origin-Opener-Policy "same-origin" always;

    location = /api/v1/inboxes {
        limit_req zone=mailwisp_create burst=4 nodelay;
        proxy_pass http://127.0.0.1:8080;
        include proxy_params;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
    }

    location ~ ^/(api|compat)/ {
        proxy_pass http://127.0.0.1:8080;
        include proxy_params;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 30s;
    }

    location ~ ^/(livez|readyz|health)$ {
        proxy_pass http://127.0.0.1:8080;
        include proxy_params;
        proxy_set_header X-Forwarded-For $remote_addr;
    }

    location = /metrics {
        return 404;
    }

    location /assets/ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache";
    }
}
